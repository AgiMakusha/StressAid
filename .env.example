# StressAid environment variables (example)
#
# Copy this file to `.env.local` and fill in values locally.
# NEVER commit real credentials. NEVER expose secrets in client code.
#
# HACKATHON BETA: only PUBLIC Supabase configuration is used. There is NO
# service-role key in the application — all authorization is enforced by
# Postgres RLS + SECURITY DEFINER RPCs.

# --- Supabase (public) ---
# Project URL and public anon key from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Application ---
# Public base URL of the deployed app; used to build absolute student links.
# Local development: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
